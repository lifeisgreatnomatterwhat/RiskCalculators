<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BRIP1 Health Strategy Simulator</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        .risk-bar { transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1); height: 28px; border-radius: 6px; }
        .bg-managed { background-color: #10b981; } 
        .bg-unmanaged { background-color: #ef4444; } 
        .bg-baseline { background-color: #94a3b8; } 
    </style>
</head>
<body class="bg-gray-100 font-sans leading-normal tracking-normal p-4 md:p-12">

    <div class="max-w-5xl mx-auto bg-white shadow-2xl rounded-2xl overflow-hidden border border-gray-200">
        <div class="bg-slate-900 p-8 text-white flex flex-col md:flex-row justify-between items-center">
            <div class="text-center md:text-left">
                <h1 class="text-3xl font-extrabold tracking-tight">BRIP1 Health Strategy Simulator</h1>
                <p class="text-slate-400 mt-2 text-sm italic">A tool to help gene mutation carriers evaluate the risks of the surgeries they are considering.</p>
            </div>
            <button onclick="downloadPhysicianGuide()" class="mt-6 md:mt-0 bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 px-6 rounded-lg shadow-lg transition-all transform hover:scale-105">
                Download Physician Guide (PDF)
            </button>
        </div>

        <div class="grid md:grid-cols-12">
            <div class="md:col-span-4 bg-slate-50 p-8 border-r border-gray-100">
                <h3 class="text-gray-500 uppercase tracking-widest text-xs font-bold mb-6">Simulation Controls</h3>
                
                <div class="space-y-8">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Genetic Mutation</label>
                        <div class="bg-white border-2 border-blue-100 p-3 rounded-md text-blue-700 font-bold text-center">BRIP1</div>
                    </div>

                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-2">Age at Intervention</label>
                        <input type="number" value="45" class="w-full p-3 bg-gray-200 border rounded-md font-bold text-lg cursor-not-allowed" readonly>
                    </div>

                    <div class="space-y-5 pt-4">
                        <label class="flex items-start space-x-3 cursor-pointer group">
                            <input type="checkbox" id="surgToggle" class="mt-1 w-5 h-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" onchange="runSimulation()">
                            <span class="text-gray-700 font-medium group-hover:text-blue-700 transition">Surgery: Path B (Total Hyst + BSO)</span>
                        </label>

                        <label class="flex items-start space-x-3 cursor-pointer group">
                            <input type="checkbox" id="hrtToggle" class="mt-1 w-5 h-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" onchange="runSimulation()">
                            <span class="text-gray-700 font-medium group-hover:text-blue-700 transition">Mitigation: Estrogen-Only HRT</span>
                        </label>

                        <label class="flex items-start space-x-3 cursor-pointer group">
                            <input type="checkbox" id="exToggle" class="mt-1 w-5 h-5 rounded border-gray-300 text-blue-600 focus:ring-blue-500" onchange="runSimulation()">
                            <span class="text-gray-700 font-medium group-hover:text-blue-700 transition">Mitigation: Resistance Training</span>
                        </label>
                    </div>
                </div>
            </div>

            <div class="md:col-span-8 p-8 md:p-12 bg-white">
                <h3 class="text-gray-500 uppercase tracking-widest text-xs font-bold mb-8">Projected Absolute Risks (per 100 Women)</h3>
                
                <div class="space-y-10">
                    <div>
                        <div class="flex justify-between items-end mb-2">
                            <span class="text-lg font-bold text-slate-800">Ovarian Cancer</span>
                            <span id="val-ovarian" class="text-xl font-black text-slate-900">10/100</span>
                        </div>
                        <div class="w-full bg-gray-100 h-7 rounded-full overflow-hidden shadow-inner">
                            <div id="bar-ovarian" class="risk-bar bg-unmanaged" style="width: 10%"></div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-2">
                            <span class="text-lg font-bold text-slate-800">Bone Fracture Risk</span>
                            <span id="val-bone" class="text-xl font-black text-slate-900">5/100</span>
                        </div>
                        <div class="w-full bg-gray-100 h-7 rounded-full overflow-hidden shadow-inner">
                            <div id="bar-bone" class="risk-bar bg-baseline" style="width: 5%"></div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-2">
                            <span class="text-lg font-bold text-slate-800">Breast Cancer Risk</span>
                            <span id="val-breast" class="text-xl font-black text-slate-900">13/100</span>
                        </div>
                        <div class="w-full bg-gray-100 h-7 rounded-full overflow-hidden shadow-inner">
                            <div id="bar-breast" class="risk-bar bg-baseline" style="width: 13%"></div>
                        </div>
                    </div>

                    <div>
                        <div class="flex justify-between
